# Backend environment configuration
# Copy this file to .env and fill in the values for your environment.

# ---- Required ----

# PostgreSQL connection string (must use postgresql+asyncpg:// scheme)
DATABASE_URL=postgresql+asyncpg://survey:survey@localhost:5432/survey

# Secret key used to sign JWT tokens — use a strong random value in production
JWT_SECRET=change-me-in-production

# ---- Environment ----

# Application environment: development | test | production
# Controls security defaults (see below). Defaults to "production".
ENVIRONMENT=development

# ---- Optional ----

# Access token lifetime in minutes (default: 60)
# JWT_EXPIRY_MINS=60

# Comma-separated list of allowed CORS origins (default: http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000

# Whether the refresh token cookie is sent only over HTTPS (Secure flag).
# Defaults to False when ENVIRONMENT is "development" or "test" so that token
# refresh works over plain HTTP on localhost. Set to true to override.
# COOKIE_SECURE=false

# Logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO
